PORT=3000
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars
JWT_EXPIRES_SECONDS=604800

# postgres (default when DB_DIALECT is omitted or postgres)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=monetro
TYPEORM_SYNC=false
TYPEORM_LOGGING=false

# optional: sqlite in-memory (used by e2e tests)
# DB_DIALECT=sqlite

# MongoDB (only if you enable MongooseModule.forRootAsync in app.module.ts)
# MONGO_URI=mongodb://localhost:27017/monetro
